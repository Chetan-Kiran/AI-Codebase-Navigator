from dotenv import load_dotenv
from groq import Groq
import os

load_dotenv()

# Lazy initialization of client
_client = None

def get_client():
    global _client
    if _client is None:
        api_key = os.getenv("GROQ_API_KEY")
        if not api_key:
            raise ValueError("GROQ_API_KEY environment variable is not set")
        _client = Groq(api_key=api_key)
    return _client

def analyze_codebase_structure(structure: str, code: str):

    prompt = f"""
You are a senior software architect.

Analyze the following repository.

IMPORTANT RULES:
- Only use the information given
- Do not guess technologies
- If unsure, say "not enough information"

REPOSITORY STRUCTURE
{structure}

CODE SNIPPETS
{code}

Explain:

1. What the project likely does
2. Architecture
3. Technologies used
4. Main components
"""

    response = get_client().chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.2
    )

    return response.choices[0].message.content

def ask_question_about_repo(context: str):

    response = get_client().chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[{"role": "user", "content": context}],
        temperature=0.2
    )

    return response.choices[0].message.content

def summarize_commits(commits: str):

    if not commits:
        return "No commits to summarize"

    try:
        prompt = f"""
You are a senior software engineer.

Analyze these git commits and summarize:

- What kind of project this is
- What work has been done
- Development stage (early / mid / mature)

COMMITS:
{commits}
"""

        response = get_client().chat.completions.create(
            model="llama-3.1-8b-instant",
            messages=[{"role": "user", "content": prompt}],
            temperature=0.3
        )

        return response.choices[0].message.content

    except Exception as e:
        return f"AI Error: {str(e)}"

def analyze_diff(diff_text: str):
    prompt = f"""
You are a senior engineer.

Explain what changed in this commit:

{diff_text}

Focus on:
- What changed
- Why it matters
- Any risks
"""

    response = get_client().chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.2
    )

    return response.choices[0].message.content

def analyze_commit_risk(commit_text: str):

    prompt = f"""
You are a senior software engineer performing code review.

Analyze this commit:

{commit_text}

Answer:

1. What changed?
2. Is this risky? (LOW / MEDIUM / HIGH)
3. Why?
4. Any potential bugs?
5. Missing tests?

Be concise.
"""

    response = get_client().chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.2
    )

    return response.choices[0].message.content

def analyze_commit_timeline(commits: str):

    prompt = f"""
You are an expert software engineer.

Analyze these commits and classify each:

For EACH commit return:
- commit id
- message
- risk level (LOW / MEDIUM / HIGH)
- short reason

COMMITS:
{commits}

Return JSON array.
"""

    response = get_client().chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.2
    )

    return response.choices[0].message.content 

def analyze_diff(diff: str):

    prompt = f"""
You are a senior engineer.

Analyze this git diff.

Explain clearly:

1. What changed
2. Why it matters
3. Any risks
4. Breaking changes

DIFF:
{diff}
"""

    response = get_client().chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.2
    )

    return response.choices[0].message.content

def groq_chat(messages, tools=None):
    return get_client().chat.completions.create(
        model="llama-3.1-8b-instant",
        messages = messages,
        tools = tools
    )

def decide_tool(User_message):
    prompt = f"""YOU are a tool selector for a coding assistant AI.
    user message:
    {User_message}
    Available tools:
    - risk_analysis -> for bug bugs/errors
    - commit_summary -> for commit history
    - diff_analysis -> for change/diff
    - bug_origin -> for finding bugwhich introduced a bug
    - repo_qa -> for general questions about the codebase

    Decide which tool to use. Only return the tool name.
    """
    return groq_chat(prompt).strip()